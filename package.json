{
  "name": "ma-cannabis-directory",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:data && astro dev",
    "build": "npm run build:data && npm run build:search && astro build",
    "build:data": "npx tsx scripts/build-data.ts",
    "build:search": "npx tsx scripts/build-search-index.ts",
