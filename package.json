    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.1",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.1.0",
    "zod": "^3.25.76"
  }
}
