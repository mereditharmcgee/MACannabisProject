---
import OwnershipBadge from './OwnershipBadge.astro';
import SiblingLinks from './SiblingLinks.astro';
import DataDisclaimer from './DataDisclaimer.astro';

interface Dispensary {
  tradeName: string;
  owner: string | null;
  parentCompany: string | null;
  address: string | null;
  town: string | null;
  phone: string | null;
  licenseType: string | null;
  lastVerified?: string | null;
  specialStatusTags: string[];
  researchInconclusive: boolean;
  [key: string]: unknown;
}

interface Narrative {
  text: string;
  type: string;
}

interface SiblingEntry {
  tradeName: string;
  slug: string;
  town: string | null;
  [key: string]: unknown;
}

interface Props {
  dispensary: Dispensary;
  narrative: Narrative;
  siblings: SiblingEntry[];
}

const { dispensary, narrative, siblings } = Astro.props;

// Build Google Maps URL
const mapsQuery = [dispensary.address, dispensary.town, 'MA'].filter(Boolean).join(', ');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapsQuery)}`;

// Format phone for tel: href (strip to digits and leading +)
const phoneHref = dispensary.phone
  ? `tel:${dispensary.phone.replace(/[^\d+]/g, '')}`
  : null;

// Determine owner display: show parentCompany if different from owner
const ownerDisplay = dispensary.owner
  ? dispensary.owner.replace(/\s*\(.*?\)\s*/g, '').trim()
  : null;
const showParentCompany =
  dispensary.parentCompany &&
  ownerDisplay &&
  dispensary.parentCompany.toLowerCase() !== ownerDisplay.toLowerCase();

// Correction form via Formspree
// Replace with your Formspree form ID after creating a form at https://formspree.io
// Free tier: 50 submissions/month. Submissions go to your email.
const FORMSPREE_FORM_ID = 'FORMSPREE_ID_PLACEHOLDER';
const FORMSPREE_URL = `https://formspree.io/f/${FORMSPREE_FORM_ID}`;
---

<a href="/" class="inline-block mb-4 text-green-700 hover:underline text-sm">&larr; Back to Directory</a>

<article class="bg-white rounded-xl shadow-md max-w-2xl mx-auto overflow-hidden">
  <div class="p-6 sm:p-8">
    {/* Header: Name and Badges */}
    <header class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">{dispensary.tradeName}</h1>
      {dispensary.specialStatusTags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {dispensary.specialStatusTags.map((tag) => (
            <OwnershipBadge tag={tag} />
          ))}
        </div>
      )}
    </header>

    {/* Owner Section (hidden for researchInconclusive) */}
    {!dispensary.researchInconclusive && ownerDisplay && (
      <section class="mb-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Owner</h2>
        <p class="text-lg text-gray-800 font-medium">{ownerDisplay}</p>
        {showParentCompany && (
          <p class="text-sm text-gray-600 mt-0.5">{dispensary.parentCompany}</p>
        )}
      </section>
    )}

    {/* Narrative Section (hidden for researchInconclusive) */}
    {!dispensary.researchInconclusive && narrative.type === 'full' && (
      <section class="mb-6">
        <p class="text-gray-700 leading-relaxed">{narrative.text}</p>
      </section>
    )}
    {!dispensary.researchInconclusive && narrative.type === 'pending' && (
      <section class="mb-6">
        <p class="text-gray-500 italic leading-relaxed">{narrative.text}</p>
      </section>
    )}

    {/* Researching Notice (for researchInconclusive) */}
    {dispensary.researchInconclusive && (
      <div class="mb-6 bg-gray-50 border border-gray-200 rounded-lg p-4">
        <p class="text-gray-600 text-sm">
          Ownership information for this dispensary is being researched.
        </p>
      </div>
    )}

    {/* Facts Section */}
    <section class="border-t border-gray-100 pt-5">
      <dl class="grid grid-cols-1 gap-4">
        {dispensary.address && (
          <div>
            <dt class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Address</dt>
            <dd class="mt-0.5">
              <a
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-green-700 hover:underline"
              >
                {dispensary.address}{dispensary.town ? `, ${dispensary.town}, MA` : ', MA'}
              </a>
            </dd>
          </div>
        )}
        {dispensary.phone && phoneHref && (
          <div>
            <dt class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Phone</dt>
            <dd class="mt-0.5">
              <a href={phoneHref} class="text-green-700 hover:underline">{dispensary.phone}</a>
            </dd>
          </div>
        )}
        {dispensary.licenseType && (
          <div>
            <dt class="text-sm font-semibold text-gray-500 uppercase tracking-wide">License Type</dt>
            <dd class="mt-0.5 text-gray-800">{dispensary.licenseType}</dd>
          </div>
        )}
      </dl>
    </section>

    {/* Sibling Links (hidden for researchInconclusive) */}
    {!dispensary.researchInconclusive && (
      <SiblingLinks siblings={siblings} />
    )}

    {/* Last Verified (conditional) */}
    {dispensary.lastVerified && (
      <div class="border-t border-gray-100 pt-4 mt-4">
        <p class="text-xs text-gray-400">
          <span class="font-semibold uppercase tracking-wide">Last Verified:</span> {dispensary.lastVerified}
        </p>
      </div>
    )}

    {/* Data Disclaimer */}
    <div class="mt-5">
      <DataDisclaimer variant="detailed" />
    </div>

    {/* Correction Form */}
    <section id="correction-form" class="mt-6 border-t border-gray-100 pt-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Suggest a Correction</h2>
      <p class="text-sm text-gray-500 mb-3">See something wrong with this listing? Let us know and we'll update it.</p>
      <form
        action={FORMSPREE_URL}
        method="POST"
        class="space-y-4"
        id="correction-form-el"
      >
        <input type="hidden" name="dispensary" value={dispensary.tradeName} />
        <div>
          <label for="correction-field" class="block text-sm font-medium text-gray-700 mb-1">What needs correcting?</label>
          <select
            id="correction-field"
            name="field"
            required
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:ring-2 focus:ring-green-500 focus:border-green-500 focus:outline-none"
          >
            <option value="">Select a field...</option>
            <option value="owner">Owner</option>
            <option value="address">Address</option>
            <option value="phone">Phone Number</option>
            <option value="license-type">License Type</option>
            <option value="ownership-tags">Ownership Tags</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="correction-value" class="block text-sm font-medium text-gray-700 mb-1">Correct information</label>
          <textarea
            id="correction-value"
            name="correction"
            required
            rows="3"
            placeholder="What should it say instead?"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:ring-2 focus:ring-green-500 focus:border-green-500 focus:outline-none resize-y"
          ></textarea>
        </div>
        <div>
          <label for="correction-email" class="block text-sm font-medium text-gray-700 mb-1">Your email <span class="text-gray-400 font-normal">(optional, for follow-up)</span></label>
          <input
            type="email"
            id="correction-email"
            name="email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:ring-2 focus:ring-green-500 focus:border-green-500 focus:outline-none"
          />
        </div>
        <button
          type="submit"
          class="w-full sm:w-auto px-6 py-2.5 bg-green-700 text-white text-sm font-medium rounded-lg hover:bg-green-800 focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors"
        >
          Submit Correction
        </button>
        <div id="correction-status" class="hidden text-sm"></div>
      </form>
    </section>

    {/* Terms of Service Link */}
    <div class="mt-4 text-center">
      <a href="/terms/" class="text-xs text-gray-400 hover:text-gray-600 underline">Terms of Service</a>
    </div>
  </div>
</article>
