---
import OwnershipBadge from './OwnershipBadge.astro';
import SiblingLinks from './SiblingLinks.astro';
import DataDisclaimer from './DataDisclaimer.astro';

interface Dispensary {
  tradeName: string;
  licenseNumber: string;
  owner: string | null;
  parentCompany: string | null;
  address: string | null;
  town: string | null;
  phone: string | null;
  licenseType: string | null;
  ownershipDetails: string | null;
  lastVerified?: string | null;
  specialStatusTags: string[];
  researchInconclusive: boolean;
  [key: string]: unknown;
}

interface Narrative {
  text: string;
  type: string;
}

interface SiblingEntry {
  tradeName: string;
  slug: string;
  town: string | null;
  licenseNumber?: string;
  [key: string]: unknown;
}

interface Props {
  dispensary: Dispensary;
  narrative: Narrative;
  siblings: SiblingEntry[];
}

const { dispensary, narrative, siblings } = Astro.props;

// Build Google Maps URL
const mapsQuery = [dispensary.address, dispensary.town, 'MA'].filter(Boolean).join(', ');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapsQuery)}`;

// Format phone for tel: href
const phoneHref = dispensary.phone
  ? `tel:${dispensary.phone.replace(/[^\d+]/g, '')}`
  : null;

// Owner display: strip parenthetical roles
const ownerDisplay = dispensary.owner
  ? dispensary.owner.replace(/\s*\(.*?\)\s*/g, '').trim()
  : null;
const showParentCompany =
  dispensary.parentCompany &&
  ownerDisplay &&
  dispensary.parentCompany.toLowerCase() !== ownerDisplay.toLowerCase();

// Legal name: parentCompany if different from tradeName
const legalName = dispensary.parentCompany &&
  dispensary.parentCompany.toLowerCase() !== dispensary.tradeName.toLowerCase()
  ? dispensary.parentCompany
  : null;

// Correction form link
const correctionUrl = `/correct/?dispensary=${encodeURIComponent(dispensary.tradeName)}`;
---

<a href="/" class="inline-block mb-4 text-green-700 hover:underline text-sm">&larr; Back to Directory</a>

<article class="bg-white rounded-xl shadow-md max-w-2xl mx-auto overflow-hidden">
  <div class="p-6 sm:p-8">

    {/* === HEADER: Trade Name + Legal Name + License Number === */}
    <header class="mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{dispensary.tradeName}</h1>
      <div class="mt-1 flex flex-wrap items-baseline gap-x-4 gap-y-1">
        {legalName && (
          <p class="text-sm text-gray-500">{legalName}</p>
        )}
        <p class="text-sm text-gray-400 font-mono">{dispensary.licenseNumber}</p>
      </div>
    </header>

    {/* === SPECIAL STATUS TAGS === */}
    {dispensary.specialStatusTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-5">
        {dispensary.specialStatusTags.map((tag) => (
          <OwnershipBadge tag={tag} />
        ))}
      </div>
    )}

    {/* === DISPENSARY INFO: Address, Phone, License Type === */}
    <section class="mb-6 space-y-2">
      {dispensary.address && (
        <div class="flex items-start gap-2">
          <svg class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-green-700 hover:underline"
          >
            {dispensary.address}{dispensary.town ? `, ${dispensary.town}, MA` : ', MA'}
          </a>
        </div>
      )}
      {dispensary.phone && phoneHref && (
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          <a href={phoneHref} class="text-sm text-green-700 hover:underline">{dispensary.phone}</a>
        </div>
      )}
      {dispensary.licenseType && (
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <p class="text-sm text-gray-600">{dispensary.licenseType}</p>
        </div>
      )}
    </section>

    {/* === DISPENSARY BIO (Narrative) === */}
    {!dispensary.researchInconclusive && narrative.type === 'full' && (
      <section class="mb-6 border-t border-gray-100 pt-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">About This Dispensary</h2>
        <p class="text-gray-700 leading-relaxed">{narrative.text}</p>
      </section>
    )}
    {!dispensary.researchInconclusive && narrative.type === 'pending' && (
      <section class="mb-6 border-t border-gray-100 pt-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">About This Dispensary</h2>
        <p class="text-gray-500 italic leading-relaxed">{narrative.text}</p>
      </section>
    )}
    {dispensary.researchInconclusive && (
      <div class="mb-6 bg-gray-50 border border-gray-200 rounded-lg p-4">
        <p class="text-gray-600 text-sm">
          Ownership information for this dispensary is being researched.
        </p>
      </div>
    )}

    {/* === OWNER / PARENT SECTION === */}
    {!dispensary.researchInconclusive && ownerDisplay && (
      <section class="mb-6 border-t border-gray-100 pt-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Owner / Parent Company</h2>
        <p class="text-lg text-gray-800 font-medium">{ownerDisplay}</p>
        {showParentCompany && (
          <p class="text-sm text-gray-600 mt-0.5">{dispensary.parentCompany}</p>
        )}
        {dispensary.ownershipDetails && (
          <p class="text-sm text-gray-600 leading-relaxed mt-2">{dispensary.ownershipDetails}</p>
        )}
      </section>
    )}

    {/* === OTHER DISPENSARIES & LICENSES OWNED === */}
    {!dispensary.researchInconclusive && (
      <SiblingLinks siblings={siblings} />
    )}

    {/* === LAST VERIFIED === */}
    {dispensary.lastVerified && (
      <div class="border-t border-gray-100 pt-4 mt-4">
        <p class="text-xs text-gray-400">
          <span class="font-semibold uppercase tracking-wide">Last Verified:</span> {dispensary.lastVerified}
        </p>
      </div>
    )}

    {/* === DATA DISCLAIMER === */}
    <div class="mt-5">
      <DataDisclaimer variant="detailed" />
    </div>

    {/* === SUGGEST A CORRECTION + TOS === */}
    <div class="mt-5 border-t border-gray-100 pt-4 flex items-center justify-between">
      <a
        href={correctionUrl}
        class="inline-flex items-center text-sm text-green-700 hover:text-green-900 hover:underline"
      >
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Suggest a Correction
      </a>
      <a href="/terms/" class="text-xs text-gray-400 hover:text-gray-600 underline">Terms of Service</a>
    </div>
  </div>
</article>
